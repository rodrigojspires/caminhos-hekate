{
  "version": 2,
  "builds": [
    {
      "src": "backend-example.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static",
      "config": {
        "excludeFiles": "backend-example.js"
      }
    },
    {
      "src": "*.{jpg,png,gif,webp,svg,ico}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend-example.js"
    },
    {
      "src": "/webhooks/(.*)",
      "dest": "/backend-example.js"
    },
    {
      "src": "/(sucesso|falha|pendente)",
      "dest": "/backend-example.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}